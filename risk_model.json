{
  "meta": {
    "name": "EVCH Additive Risk Score",
    "version": "1.0.0",
    "disclaimer": "Screening tool only. Not a diagnostic instrument."
  },

  "questions": [

    {
      "id": "edad",
      "label": "Edad (años)",
      "type": "numeric",
      "range": { "min": 0, "max": 120 },
      "category": "Datos Personales",
      "thresholds": [
        { "max": 54, "points": 1 },
        { "max": 64, "points": 2 },
        { "min": 65, "points": 3 }
      ]
    },
    {
      "id": "sexo",
      "label": "Sexo",
      "type": "categorical",
      "category": "Datos Personales",
      "options": { "Mujer": 1, "Hombre": 2 }
    },

    {
      "id": "pas",
      "label": "Presion Arterial Sistólica (mmHg)",
      "type": "numeric",
      "category": "Enfermedades no Transmisibles",
      "range": { "min": 50, "max": 300 },
      "thresholds": [
        { "max": 129, "points": 1 },
        { "max": 160, "points": 3 },
        { "min": 161, "points": 3 }
      ]
    },
    {
      "id": "pad",
      "label": "Presion Arterial Diastólica (mmHg)",
      "type": "numeric",
      "category": "Enfermedades no Transmisibles",
      "range": { "min": 25, "max": 200 },
      "thresholds": [
        { "max": 129, "points": 0 },
        { "max": 160, "points": 0 },
        { "min": 161, "points": 0 }
      ]
    },
    {
      "id": "Diabetes Mellitus tipo I HbA1c",
      "label": "HbA1c (%) - Si no tiene DM I marque 0",
      "type": "numeric",
      "range": { "min": 0, "max": 100 },
      "category": "Enfermedades no Transmisibles",
      "thresholds": [
        { "max": 1, "points": 0 },
        { "max": 6.9, "points": 1 },
        { "max": 8.7, "points": 2 },
        { "max": 9.5, "points": 3 },
        { "min": 9.6, "points": 4 }
      ]
    },
    {
      "id": "Diabetes Mellitus tipo II HbA1c",
      "label": "HbA1c (%) - Si no tiene DM II marque 0",
      "type": "numeric",
      "range": { "min": 0, "max": 100 },
      "category": "Enfermedades no Transmisibles",
      "thresholds": [
        { "max": 1, "points": 0 },
        { "max": 9.5, "points": 1 },
        { "min": 9.6, "points": 2 }
      ]
    },

    {
      "id": "embarazo",
      "label": "Embarazo",
      "type": "binary",
      "category": "Antecedentes Médicos",
      "options": { "NO": 1, "SI": 2 }
    },
    {
      "id": "nafld",
      "label": "NAFLD",
      "type": "binary",
      "category": "Antecedentes Médicos",
      "options": { "NO": 1, "SI": 2 }
    },
    {
      "id": "fibrosis",
      "label": "Fibrosis Hepática Avanzada",
      "type": "binary",
      "category": "Antecedentes Médicos",
      "options": { "NO": 1, "SI": 2 }
    },

    {
      "id": "apo_mut",
      "label": "Mutación Gen Apolipoproteína",
      "type": "binary",
      "category": "Mutaciones",
      "options": { "NO": 1, "SI": 3 }
    },
    {
      "id": "amy_mut",
      "label": "Mutaciones en las proteínas precursoras de amiloide",
      "type": "binary",
      "category": "Mutaciones",
      "options": { "NO": 1, "SI": 4 }
    },
    {
      "id": "microbleed",
      "label": "Microsangrado Cerebrales Previos",
      "type": "categorical",
      "category": "Antecedentes Médicos",
      "options": { 
        "Ninguna": 1, 
        "Entre 1 y 4": 2,  
        "5 o más": 3
      }
    },

    {
      "id": "alcoholismo",
      "label": "Alcoholismo Crónico",
      "type": "binary",
      "category": "Toxicomanías",
      "options": { "NO": 1, "SI": 3 }
    },
    {
      "id": "abuso_alcohol",
      "label": "Abuso de Alcohol (atracón de alcohol)",
      "type": "binary",
      "category": "Toxicomanías",
      "options": { "NO": 1, "SI": 2 }
    },
    {
      "id": "sustancias",
      "label": "Abuso de Sustancias illícitas",
      "type": "binary",
      "category": "Toxicomanías",
      "options": { "NO": 1, "SI": 3 }
    },
    {
      "id": "metanfetaminas",
      "label": "Abuso de Metanfetaminas y simpaticomiméticos",
      "type": "binary",
      "category": "Toxicomanías",
      "options": { "NO": 1, "SI": 3 }
    },

    {
      "id": "meningioma",
      "label": "Meningioma",
      "type": "binary",
      "category": "Cáncer",
      "options": { "NO": 1, "SI": 2 }
    },
    {
      "id": "hemangioblastoma",
      "label": "Hemangioblastoma",
      "type": "binary",
      "category": "Cáncer",
      "options": { "NO": 1, "SI": 2 }
    },
    {
      "id": "glioblastoma",
      "label": "Glioblastoma",
      "type": "binary",
      "category": "Cáncer",
      "options": { "NO": 1, "SI": 3 }
    },
    {
      "id": "adenoma",
      "label": "Adenoma Pituitario",
      "type": "binary",
      "category": "Cáncer",
      "options": { "NO": 1, "SI": 3 }
    },
    {
      "id": "metastasis",
      "label": "Metástasis Cerebral",
      "type": "binary",
      "category": "Cáncer",
      "options": { "NO": 1, "SI": 3 }
    },

    {
      "id": "anticonceptivos",
      "label": "Anticonceptivos Orales",
      "type": "binary",
      "category": "Medicamentos",
      "options": { "NO": 1, "SI": 2 }
    },
    {
      "id": "antiagregacion",
      "label": "Terapia Antiplaquetaria",
      "type": "categorical",
      "category": "Medicamentos",
      "options": {
        "Ninguno": 1,
        "Simple (un solo medicamento)": 2,
        "Dual": 3
      }
    }
    
  ]

}
